@page
@model GlassStore.Pages.Customer.ProductListModel
@inject CartService CartService
@using GlassStore.Helpers

@{
    var cart = CartService.GetCart();
    var total = CartService.GetTotal();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Danh sách sản phẩm</h2>
        <a asp-page="/Customer/OrderHistory" class="btn btn-outline-info px-4 py-2">
            Xem lịch sử đơn hàng
        </a>
    </div>

    <div class="row">
        <!-- PRODUCT -->
        <div class="col-md-8">
            <div class="row">
                @foreach (var item in Model.Products)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm h-100">
                            <img src="https://via.placeholder.com/200" class="card-img-top" />

                            <div class="card-body">
                                <h5>@item.Name</h5>

                                <p class="text-danger fw-bold">
                                    @CurrencyHelper.ToVnd(item.Price)
                                </p>

                                <form method="post">
                                    <input type="hidden" name="ProductId" value="@item.ProductId" />

                                    <div class="d-flex gap-2">
                                        <input type="number"
                                               name="Quantity"
                                               value="1"
                                               min="1"
                                               class="form-control"
                                               style="width:70px" />

                                        @if (item.Stock > 0)
                                        {
                                            <button type="submit" class="btn btn-success btn-sm">
                                                🛒 Thêm
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-secondary btn-sm"
                                                    disabled>
                                                Hết hàng
                                            </button>
                                        }
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- CART -->
        <div class="col-md-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header bg-warning text-dark text-center">
                    <h5 class="mb-0">Giỏ hàng của bạn</h5>
                </div>

                <div class="card-body">
                    @if (cart == null || cart.Count == 0)
                    {
                        <p class="text-muted text-center my-3">
                            Giỏ hàng đang trống.
                        </p>
                    }
                    else
                    {
                        <ul class="list-group mb-3">
                            @foreach (var cartItem in cart)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center lh-sm">
                                    <div>
                                        <h6 class="my-0">@cartItem.Name</h6>

                                        <small class="text-muted">
                                            SL: @cartItem.Quantity x
                                            @CurrencyHelper.ToVnd(cartItem.Price)
                                        </small>
                                    </div>

                                    <div class="d-flex align-items-center gap-1">
                                        <span class="text-muted fw-bold me-2">
                                            @CurrencyHelper.ToVnd(
                                            cartItem.Quantity* cartItem.Price
                                                                        )
                                </span>

                                <form method="post" class="m-0 d-inline">
                                    <button type="submit"
                                            asp-page-handler="Decrease"
                                            asp-route-removeId="@cartItem.ProductId"
                                            class="btn btn-outline-warning btn-sm px-2 py-0 fw-bold">
                                        -
                                    </button>
                                </form>

                                <form method="post" class="m-0 d-inline">
                                    <button type="submit"
                                            asp-page-handler="RemoveAll"
                                            asp-route-removeId="@cartItem.ProductId"
                                            class="btn btn-outline-danger btn-sm px-2 py-0 fw-bold">
                                        x
                                    </button>
                                </form>
                            </div>
                        </li>
                                                }
                        </ul>

                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Tổng cộng:</span>
                            <span class="text-danger">
                                @CurrencyHelper.ToVnd(total)
                            </span>
                        </div>

                        <a href="/Customer/Checkout"
                           class="btn btn-success w-100 py-2">
                            💳 Thanh toán ngay
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>