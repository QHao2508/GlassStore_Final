@page
@model GlassStore.Pages.Admin.IndexModel
@using System.Globalization
@{
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">

    <!-- TITLE -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h2 class="fw-bold">📊 Bảng điều khiển</h2>
        <span class="text-muted">Xin chào, Admin 👋</span>
    </div>

    <!-- STATS -->
    <div class="row g-4">

        <!-- Products -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-primary text-white shadow">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="small">Sản phẩm</div>
                        <div class="fs-3 fw-bold">@Model.TotalProducts</div>
                    </div>
                    <i class="fas fa-box fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

        <!-- Stock -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-success text-white shadow">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="small">Tồn kho</div>
                        <div class="fs-3 fw-bold">@Model.TotalStock</div>
                    </div>
                    <i class="fas fa-warehouse fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-warning text-white shadow">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="small">Đơn hàng</div>
                        <div class="fs-3 fw-bold">@Model.TotalOrders</div>
                    </div>
                    <i class="fas fa-shopping-cart fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

        <!-- Revenue -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-danger text-white shadow">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="small">Doanh thu</div>
                        <div class="fs-3 fw-bold">
                            @string.Format(new CultureInfo("vi-VN"), "{0:c0}", Model.TotalRevenue)
                        </div>
                    </div>
                    <i class="fas fa-money-bill-wave fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

    </div>

    <!-- EXTRA -->
    <div class="row mt-5">

        <!-- Revenue Today -->
        <div class="col-md-6">
            <div class="card shadow border-0 p-4">
                <h5 class="mb-3">💰 Doanh thu hôm nay</h5>
                <h3 class="text-success">
                    @string.Format(new CultureInfo("vi-VN"), "{0:c0}", Model.RevenueToday)
                </h3>
            </div>
        </div>

        <!-- Placeholder Chart -->
        <div class="col-md-6">
            <div class="card shadow border-0 p-4">
                <h5 class="mb-3">📈 Tổng quan bán hàng</h5>
                <p class="text-muted">Biểu đồ sẽ sớm được cập nhật...</p>
            </div>
        </div>

    </div>

</div>

<!-- STYLE -->
<style>
    .stat-card {
        border: none;
        border-radius: 15px;
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .card i {
        opacity: 0.3;
    }
</style>