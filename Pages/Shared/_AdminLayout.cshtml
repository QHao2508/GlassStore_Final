<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Quản trị - NoScope Glass</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Sidebar */
        .sidebar {
            width: 240px;
            height: 100vh;
            background: #111;
            position: fixed;
            top: 0;
            left: 0;
            box-shadow: 4px 0 10px rgba(0,0,0,0.2);
        }

            .sidebar h4 {
                color: white;
                text-align: center;
                padding: 20px 0;
                border-bottom: 1px solid #333;
                letter-spacing: 1px;
            }

            .sidebar a {
                display: block;
                color: #ccc;
                padding: 12px 20px;
                text-decoration: none;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #333;
                    color: white;
                }

                .sidebar a.active {
                    background: #0d6efd;
                    color: white;
                    font-weight: bold;
                }

        /* Content */
        .content {
            margin-left: 240px;
            padding: 25px;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>ADMIN</h4> 
        <a asp-page="/Admin/Index">Tác Vụ</a> 
        <a asp-page="/Admin/Products/Index">Sản Phẩm</a>
        <a asp-page="/Logout">Đăng Xuất</a>
        <a asp-page="/Admin/Orders">Quản lý đơn hàng</a>
    </div>

    <!-- CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

</body>
</html>