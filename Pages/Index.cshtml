@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- HERO -->
<div class="bg-dark text-white text-center p-5 rounded shadow">
    <h1 class="display-3 fw-bold">👓 NoScope Glass</h1>
    <p class="lead">Bộ sưu tập kính cao cấp</p>

    <a href="/Customer/ProductList" class="btn btn-light btn-lg m-2 px-4">
        Mua ngay
    </a>
</div>

<!-- FEATURES -->
<div class="container mt-5">
    <div class="row text-center g-4">

        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h3>🕶 Thời Trang</h3>
                <p>Kính phong cách hiện đại</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h3>👓 Kính Thuốc</h3>
                <p>Tròng kính chất lượng cao</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h3>🚚 Vận Chuyển</h3>
                <p>Giao hàng nhanh toàn quốc</p>
            </div>
        </div>

    </div>
</div>

<!-- CTA -->
<div class="text-center mt-5 mb-5">
    <a href="/Customer/ProductList" class="btn btn-dark btn-lg px-5 shadow">
        Tìm kiếm sản phẩm ngay hôm nay
    </a>
</div>